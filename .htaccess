# CodeAcademy .htaccess - Versión Segura para Apache 2.4

# Desactivar el listado de carpetas
Options -Indexes

# Protección del archivo .env y archivos .sql (Sintaxis Apache 2.4)
<FilesMatch "^\.env|.*\.sql$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Protección de la carpeta includes
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Si alguien intenta entrar a /includes/ directamente, lanzar error 403 Forbidden
    RewriteRule ^includes/.*$ - [F,L]
</IfModule>

# Establecer la página de inicio
DirectoryIndex index.php
